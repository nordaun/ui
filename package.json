{
  "name": "ui",
  "version": "2.0.0",
  "description": "A collection of beatifully designed components that extend the boundaries of shadcn while staying consistent, modular and of course clean.",
  "homepage": "https://ui.nordaun.com",
  "author": "vorhdam <https://github.com/vorhdam>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nordaun/ui.git"
  },
  "keywords": [
    "shadcn",
    "registry",
    "react",
    "ui",
    "base"
  ],
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "package:build": "turbo run package:build",
    "package:dev": "turbo run package:dev"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "tsup": "^8.5.1",
    "turbo": "^2.9.12",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
