{
  "name": "@nordaun/theme",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.tsx"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "generate:component": "turbo gen react-component",
    "check-types": "tsc --noEmit",
    "package:build": "tsup ./src/index.tsx --format cjs,esm --dts",
    "package:dev": "tsup ./src/index.tsx --format cjs,esm --dts --watch"
  },
  "devDependencies": {
    "@repo/eslint": "*",
    "@repo/typescript": "*",
    "@types/node": "^20",
    "eslint": "^9.39.1",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@types/js-cookie": "^3.0.6",
    "@types/react": "^19.2.14",
    "js-cookie": "^3.0.5",
    "react": "^19.2.6"
  }
}
