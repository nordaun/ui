        {
          "path": "src/components/ui/audio.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "file",
      "title": "File",
      "description": "A context-based file uploader with customizable texts and icons and a built-in workflow.",
      "author": "vorhdam <https://github.com/vorhdam>",
      "type": "registry:block",
      "dependencies": ["lucide-react"],
      "registryDependencies": ["alert", "button", "progress"],
